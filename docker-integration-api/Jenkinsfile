pipeline {
    agent any

    tools {
        maven 'maven-3.9.6'
    }

    stages {
        stage('Build JAR') {
            steps {
                dir('docker-integration-api') {
                    bat 'mvn clean install'
                }
            } 
        }
        
        stage('Build Docker Image'){
			steps{
				dir('docker-integration-api') {
                    bat 'docker build -t saikumar1605/docker-jenkins-integration .'
				}
			}
		}
    }
}